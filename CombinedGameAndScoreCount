  .syntax unified
  .cpu cortex-m4
  .fpu softvfp
  .thumb
  
  .global Main
  .global SysTick_Handler
  .global EXTI0_IRQHandler

  #include "definitions.S"

  .equ    BLINK_PERIOD, 1000

  .section .text
  .type Main, %function
Main:
  PUSH  {R4-R6,LR}

  LDR     R4, =RCC_AHBENR
  LDR     R5, [R4]
  ORR     R5, R5, #(0b1 << (RCC_AHBENR_GPIOEEN_BIT))
  STR     R5, [R4]

  LDR     R4, =GPIOE_MODER
  LDR     R5, [R4]
  LDR     R6, =0b1111111111111111<<(LD4_PIN*2)
  BIC     R5, R6
  LDR     R6, =0b0101010101010101<<(LD4_PIN*2)
  ORR     R5, R6
  STR     R5, [R4]

  LDR     R4, =blink_countdown
  LDR     R5, =BLINK_PERIOD
  STR     R5, [R4]

  LDR     R4, =SCB_ICSR
  LDR     R5, =SCB_ICSR_PENDSTCLR
  STR     R5, [R4]

  LDR     R4, =SYSTICK_CSR
  LDR     R5, =0
  STR     R5, [R4]

  LDR     R4, =SYSTICK_LOAD
  LDR     R5, =7999
  STR     R5, [R4]

  LDR     R4, =SYSTICK_VAL
  LDR     R5, =0x1
  STR     R5, [R4]

  LDR     R4, =SYSTICK_CSR
  LDR     R5, =0x7
  STR     R5, [R4]

  LDR   R4, =score_count
  MOV   R5, #0
  STR   R5, [R4]

  LDR   R4, =led_state
  MOV   R5, #1
  STR   R5, [R4]

  LDR   R4, =button_press
  MOV   R5, #0
  STR   R5, [R4]

  LDR   R4, =game_over
  MOV   R5, #0
  STR   R5, [R4]

  LDR   R4, =blink_count
  MOV   R5, #0
  STR   R5, [R4]

  LDR   R4, =game_over_phase
  MOV   R5, #0
  STR   R5, [R4]

  LDR   R4, =score_blink_count
  MOV   R5, #0
  STR   R5, [R4]

Idle_Loop:
  B Idle_Loop


SysTick_Handler:
  PUSH  {R4-R6, LR}

  LDR   R4, =blink_countdown
  LDR   R5, [R4]
  CMP   R5, #0
  BEQ   .LelseFire

  SUB   R5, R5, #1
  STR   R5, [R4]
  B     .LendIfDelay

.LelseFire:

  LDR     R4, =led_state
  LDR     R0, [R4]

  CMP     R0, #0b100000
  BNE     .LendIfTarget

  LDR     R5, =button_press
  LDR     R5, [R5]
  CMP     R5, #1
  BNE     .LelseIfButtton

  LDR     R5, =score_count
  LDR     R6, [R5]
  ADD     R6, R6, #1
  STR     R6, [R5]
  B       .LendIfButton

.LelseIfButtton:

  LDR     R5, =game_over
  MOV     R6, #1
  STR     R6, [R5]

  MOV     R0, #0b11111111

.LendIfButton:
.LendIfTarget:

  LDR R5, =game_over
  LDR R5, [R5]
  CMP R5, #1
  BNE .LnormalPlay

  B .LendIfGameOver

.LnormalPlay:

  LSL     R0, R0, #1

  TST     R0, #0b11111111
  BNE     .LendState
  MOV     R0, #1

.LendState:

.LendIfGameOver:

  LDR R4, =led_state
  STR R0, [R4]

  BL setLEDs

  LDR     R4, =button_press
  MOV     R5, #0
  STR     R5, [R4]

  LDR     R4, =blink_countdown
  LDR     R5, =BLINK_PERIOD
  STR     R5, [R4]

.LendIfDelay:

  LDR     R4, =SCB_ICSR
  LDR     R5, =SCB_ICSR_PENDSTCLR
  STR     R5, [R4]

  POP  {R4-R6, PC}


EXTI0_IRQHandler:

  PUSH  {R4,R5,LR}

  LDR   R4, =button_press
  MOV   R5, #1
  STR   R5, [R4]

  LDR   R4, =EXTI_PR
  MOV   R5, #(1<<0)
  STR   R5, [R4]

  POP  {R4,R5,PC}


setLEDs:

  PUSH    {R4-R6,LR}

  LDR     R5, =GPIOE_ODR
  LDR     R6, [R5]
  LDR     R4, =0b11111111<<(LD4_PIN)
  BIC     R6, R6, R4
  ORR     R6, R6, R0, LSL LD4_PIN
  STR     R6, [R5]

  POP     {R4-R6,PC}


.section .data

score_count:
  .space 4

blink_countdown:
  .space 4

led_state:
  .space 4

button_press:
  .space 4

game_over:
  .space 4

blink_count:
  .space 4

game_over_phase:
  .space 4

score_blink_count:
  .space 4

.end
